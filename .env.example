# Email — Resend (https://resend.com — free tier: 3,000 emails/month)
# 1. Sign up at resend.com
# 2. Create an API key
# 3. Copy this file to .env.local and paste your key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Order notification email (where orders & contact messages get sent)
ORDER_EMAIL=lhagvajavproo@gmail.com

# Public site URL — used for canonical links, sitemap, robots, OG tags.
# Production дээр өөрийн домэйнаар солино уу.
NEXT_PUBLIC_SITE_URL=https://nokhor.mn

# Firebase Firestore — захиалга хадгалах (заавал биш).
# Service account JSON-ийг нэг мөрөнд. Тохируулаагүй бол захиалга зөвхөн
# имэйл/console-д бичигдэнэ. Дэлгэрэнгүй: FIREBASE.md
FIREBASE_SERVICE_ACCOUNT=

# /admin хуудсыг хамгаалах нууц үг (хоосон бол нээлттэй demo горим).
ADMIN_PASSWORD=
