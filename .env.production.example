# ── Production орчны хувьсагч ──
# Энэ файлыг .env.production болгож хуулаад утгуудыг бөглөнө үү.
# (.env.production-ийг git-д commit ХИЙХГҮЙ — .gitignore-д орсон.)

# Захиалга/холбоо барих имэйл (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ORDER_EMAIL=info@nokhor.mn

# Жинхэнэ домэйн (canonical, sitemap, robots, OG tag-д ашиглагдана).
# Домэйноо Datacom дээр тохируулсны дараа энд бичнэ.
NEXT_PUBLIC_SITE_URL=https://nokhor.mn

# ── Firebase (захиалга хадгалах Firestore) ──
# Firebase console → Project settings → Service accounts → "Generate new private key"
# татаж авсан JSON-ийг НЭГ МӨРӨНД хийж (newline-уудыг \n болгож) энд тавина.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com"}

# ── Admin самбарын нууц үг ──
# Тохируулбал /admin хуудас нууц үг асууна. Хоосон бол нээлттэй (demo).
ADMIN_PASSWORD=
